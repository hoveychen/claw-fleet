{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "decision-float",
  "description": "Capability for the floating decision window that appears when the main window is minimized",
  "windows": ["decision-float"],
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "core:window:allow-close",
    "core:event:default",
    "store:default",
    "clipboard-manager:default",
    "dialog:default"
  ]
}
