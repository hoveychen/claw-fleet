{
  "expo": {
    "name": "Claw Fleet",
    "slug": "claw-fleet-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "claw-fleet",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clawfleet.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan QR codes and capture photos to attach to agent answers",
        "NSPhotoLibraryUsageDescription": "Access to your photos is required to attach images to agent answers",
        "NSLocalNetworkUsageDescription": "Claw Fleet needs local network access to connect to the desktop app",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.clawfleet.mobile",
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Claw Fleet to access the camera for QR code scanning."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1"
        }
      ],
      "./plugins/withAndroidMinify"
    ]
  }
}
